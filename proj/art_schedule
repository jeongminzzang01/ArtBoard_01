  const teamStats = {};
  teams.forEach(tm => {
    const tmIds = new Set(tm.members.map(m => m.id));
    const tmTasks = msTasks.filter(tk => tmIds.has(tk.memberId));
    if (tmTasks.length === 0) return;
    const done = tmTasks.filter(tk => tk.status === "done").length;
    const leave = tmTasks.filter(tk => tk.status === "leave").length;
    const base = tmTasks.length - leave || 1;
    teamStats[tm.name] = { total: tmTasks.length, done, leave, rate: Math.round((done / base) * 100) };
  });
  const totalUpdateItems = Object.values(msUpdates).reduce((s, e) => s + (e.items?.length || 0), 0);
  const delayCount = msTasks.filter(tk => tk.status !== "leave" && tk.endDate > ams.endDate).length;
  const leaveCount = msTasks.filter(tk => tk.status === "leave").length;
  const statBox = { background: dk ? "#191b22" : "#f6f8fa", padding: 12, borderRadius: 8, border: `1px solid ${dk ? "#282b38" : "#d0d7de"}` };
  return (
    <div>
      <div style={{ marginBottom: 16 }}>
        <div style={{ fontSize: 15, fontWeight: 700, color: t.text }}>{ams.name} {"\uC694\uC57D"}</div>
        <div style={{ fontSize: 12, color: t.textDim }}>{fmtDateKR(ams.startDate)} ~ {fmtDateKR(ams.endDate)}</div>
      </div>
      <div style={{ display: "grid", gridTemplateColumns: "1fr 1fr", gap: 8, marginBottom: 16 }}>
        {[{ label: "\uCD1D \uC791\uC5C5", value: msTasks.length }, { label: "\uC5C5\uB370\uC774\uD2B8 \uD56D\uBAA9", value: totalUpdateItems }, { label: "\uC9C0\uC5F0 \uAC74\uC218", value: delayCount }, { label: "\uC5F0\uCC28 \uC0AC\uC6A9", value: leaveCount }].map(s => (
          <div key={s.label} style={statBox}>
            <div style={{ fontSize: 11, color: t.textDim }}>{s.label}</div>
            <div style={{ fontSize: 18, fontWeight: 700, color: t.text }}>{s.value}</div>
          </div>
        ))}
      </div>
      <div style={{ fontSize: 13, fontWeight: 600, color: t.text, marginBottom: 8 }}>{"\uD300\uBCC4 \uD604\uD669"}</div>
      {Object.keys(teamStats).length === 0 ? (
        <div style={{ fontSize: 12, color: t.textDim, fontStyle: "italic" }}>{"\uD300 \uB370\uC774\uD130 \uC5C6\uC74C"}</div>
      ) : Object.entries(teamStats).map(([name, st]) => (
        <div key={name} style={{ display: "flex", justifyContent: "space-between", padding: "6px 0", borderBottom: `1px solid ${dk ? "#282b38" : "#d0d7de"}`, fontSize: 12, color: t.text }}>
          <span>{name}</span>
          <span>{st.done}/{st.total} ({st.rate}%){st.leave > 0 ? ` / \uC5F0\uCC28 ${st.leave}` : ""}</span>
        </div>
      ))}
    </div>
  );
}

