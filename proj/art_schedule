      <button onClick={doSave} style={{ width: "100%", padding: 12, background: t.btnBg, border: "none", borderRadius: 8, color: t.btnFg, cursor: "pointer", fontWeight: 700, fontSize: 14, marginTop: 10 }}>저장</button>
