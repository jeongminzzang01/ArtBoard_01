}

// ─── TeamConfigView ───
function TeamConfigView({ t, mode, isMobile, teams, setTeams, teamColors, setTeamColors, defaultCollapsedTeams, setDefaultCollapsedTeams, displaySettings, setDisplaySettings, tasks, setTasks, pushUndo, collapsedTeams, setCollapsedTeams, teamConfigSubTab, setTeamConfigSubTab, selectedConfigTeamId, setSelectedConfigTeamId }) {
  const [editingName, setEditingName] = useState(null);
  const [addingMember, setAddingMember] = useState(false);
  const [newMemberName, setNewMemberName] = useState("");
  const [newMemberRole, setNewMemberRole] = useState("원화");
  const [editingMemberId, setEditingMemberId] = useState(null);
  const [editFields, setEditFields] = useState({});
  const [confirmDel, setConfirmDel] = useState(null);
  const [teamDragIdx, setTeamDragIdx] = useState(null);
  const [teamDragOverIdx, setTeamDragOverIdx] = useState(null);

  const selectedTeam = teams.find(x => x.id === selectedConfigTeamId);
  const taskCountByMember = useMemo(() => { const m = {}; tasks.forEach(tk => { m[tk.memberId] = (m[tk.memberId] || 0) + 1; }); return m; }, [tasks]);

  const subTabBtn = (id, label) => (
    <button onClick={() => setTeamConfigSubTab(id)}
      style={{ padding: "8px 16px", background: teamConfigSubTab === id ? t.btnBg : "transparent", border: `1px solid ${teamConfigSubTab === id ? t.btnBg : t.border}`, borderRadius: 6, color: teamConfigSubTab === id ? t.btnFg : t.textDim, cursor: "pointer", fontSize: 12, fontWeight: 700 }}>
      {label}
    </button>
  );

  const handleTeamDragStart = (e, idx) => { setTeamDragIdx(idx); e.dataTransfer.effectAllowed = "move"; };
  const handleTeamDragOver = (e, idx) => { e.preventDefault(); setTeamDragOverIdx(idx); };
  const handleTeamDrop = (idx) => {
    if (teamDragIdx !== null && teamDragIdx !== idx) { pushUndo("팀 순서 변경"); setTeams(prev => { const a = [...prev]; const [r] = a.splice(teamDragIdx, 1); a.splice(idx, 0, r); return a; }); }
    setTeamDragIdx(null); setTeamDragOverIdx(null);
  };
  const handleTeamDragEnd = () => { setTeamDragIdx(null); setTeamDragOverIdx(null); };

  const addTeam = () => {
    const name = prompt("새 팀 이름을 입력하세요:");
    if (!name || !name.trim()) return;
    pushUndo("팀 추가");
    const newId = "t_" + Date.now();
    setTeams(p => [...p, { id: newId, name: name.trim(), members: [] }]);
    setSelectedConfigTeamId(newId);
  };

  const deleteTeam = (team) => {
    const totalTasks = team.members.reduce((s, m) => s + (taskCountByMember[m.id] || 0), 0);
    if (totalTasks > 0) {
      setConfirmDel({ title: "팀 삭제", message: `"${team.name}"에 ${totalTasks}건의 작업이 있습니다.\n작업을 함께 삭제하시겠습니까?`, onConfirm: () => {
        pushUndo("팀 삭제");
        const memberIds = new Set(team.members.map(m => m.id));
        setTasks(p => p.filter(tk => !memberIds.has(tk.memberId)));
        setTeams(p => p.filter(x => x.id !== team.id));
        setSelectedConfigTeamId(null); setConfirmDel(null);
      }});
    } else {
      pushUndo("팀 삭제");
      setTeams(p => p.filter(x => x.id !== team.id));
      setSelectedConfigTeamId(null);
    }
  };

  const addMemberToTeam = () => {
    if (!newMemberName.trim() || !selectedTeam) return;
    pushUndo("인원 추가");
    setTeams(p => p.map(x => x.id === selectedTeam.id ? { ...x, members: [...x.members, { id: "m_" + Date.now(), name: newMemberName.trim(), email: "", role: "사원", concurrent: false, roles: ["사원"], functionalRole: newMemberRole }] } : x));
    setNewMemberName(""); setAddingMember(false);
  };

  const removeMember = (memberId) => {
    const tc = taskCountByMember[memberId] || 0;
    const member = selectedTeam.members.find(m => m.id === memberId);
    setConfirmDel({ title: "인원 제거", message: `"${member?.name}"님을 제거하시겠습니까?${tc > 0 ? `\n관련 일정 ${tc}건이 함께 삭제됩니다.` : ""}`, onConfirm: () => {
      pushUndo("인원 제거");
      setTeams(p => p.map(x => x.id === selectedTeam.id ? { ...x, members: x.members.filter(m => m.id !== memberId) } : x));
      setTasks(p => p.filter(tk => tk.memberId !== memberId));
      setConfirmDel(null); setEditingMemberId(null);
    }});
  };

  const saveMemberEdit = (memberId) => {
    const f = editFields;
    pushUndo("인원 수정");
    setTeams(p => p.map(x => x.id === selectedTeam.id ? { ...x, members: x.members.map(m => m.id === memberId ? { ...m, name: f.name || m.name, functionalRole: f.functionalRole || m.functionalRole, p4Account: f.p4Account !== undefined ? f.p4Account : (m.p4Account || ""), memo: f.memo !== undefined ? f.memo : (m.memo || "") } : m) } : x));
    setEditingMemberId(null); setEditFields({});
  };

  const setLeader = (memberId) => {
    pushUndo("팀장 지정");
    setTeams(p => p.map(x => x.id === selectedTeam.id ? { ...x, members: x.members.map((m, i) => {
      if (m.id === memberId) return { ...m, role: "팀장", roles: ["팀장"] };
      if (m.role === "팀장") return { ...m, role: "사원", roles: ["사원"] };
      return m;
    })} : x));
  };

  const renameTeam = (newName) => {
    if (!newName.trim()) return;
    pushUndo("팀 이름 변경");
    setTeams(p => p.map(x => x.id === selectedTeam.id ? { ...x, name: newName.trim() } : x));
    setEditingName(null);
  };

  const iS = { width: "100%", padding: "8px 10px", background: t.inputBg, border: `1px solid ${t.inputBorder}`, color: t.text, borderRadius: 6, fontSize: 13, boxSizing: "border-box", outline: "none" };

  // ── 멤버 드래그 순서 변경 ──
  const [mDragIdx, setMDragIdx] = useState(null);
  const [mDragOverIdx, setMDragOverIdx] = useState(null);
  const handleMemberDrop = (toIdx) => {
    if (mDragIdx !== null && mDragIdx !== toIdx && selectedTeam) {
      pushUndo("멤버 순서 변경");
      setTeams(p => p.map(x => { if (x.id !== selectedTeam.id) return x; const ms = [...x.members]; const [r] = ms.splice(mDragIdx, 1); ms.splice(toIdx, 0, r); return { ...x, members: ms }; }));
    }
    setMDragIdx(null); setMDragOverIdx(null);
  };

  return (
    <div style={{ flex: 1, display: "flex", flexDirection: "column", overflow: "hidden", minHeight: 0 }}>
      {/* 서브탭 */}
      <div style={{ display: "flex", gap: 6, padding: "8px 16px", borderBottom: `1px solid ${t.border}`, background: t.headerBg, flexShrink: 0 }}>
        {subTabBtn("members", "팀/인원 관리")}{subTabBtn("display", "표시 설정")}
      </div>

      {/* 팀/인원 관리 */}
      {teamConfigSubTab === "members" && (
        <div style={{ flex: 1, display: "flex", overflow: "hidden", minHeight: 0 }}>
          {/* 좌측 팀 목록 */}
          <div style={{ width: isMobile ? "100%" : 250, flexShrink: 0, borderRight: isMobile ? "none" : `1px solid ${t.border}`, background: mode === "dark" ? "#191b22" : "#f6f8fa", display: "flex", flexDirection: "column", overflow: "hidden" }}>
            <div style={{ flex: 1, overflowY: "auto", padding: 8 }}>
              {teams.map((team, idx) => {
                const isDragOver = teamDragOverIdx === idx && teamDragIdx !== idx;
                return (
                  <div key={team.id} draggable onDragStart={(e) => handleTeamDragStart(e, idx)} onDragOver={(e) => handleTeamDragOver(e, idx)} onDrop={() => handleTeamDrop(idx)} onDragEnd={handleTeamDragEnd}
                    onClick={() => setSelectedConfigTeamId(team.id)}
                    style={{ padding: "10px 12px", marginBottom: 4, background: selectedConfigTeamId === team.id ? (mode === "dark" ? "#222430" : "#eaeef2") : (mode === "dark" ? "#1e2029" : "#ffffff"), border: `1px solid ${selectedConfigTeamId === team.id ? t.accent : (mode === "dark" ? "#282b38" : "#d0d7de")}`, borderLeft: selectedConfigTeamId === team.id ? `3px solid ${t.accent}` : `3px solid transparent`, borderTop: isDragOver ? `3px solid ${t.accent}` : undefined, borderRadius: 6, cursor: "pointer", display: "flex", alignItems: "center", gap: 10, transition: "background .15s" }}>
                    <span style={{ width: 10, height: 10, borderRadius: "50%", background: teamColors[team.id] || TEAM_PRESET_COLORS[idx % TEAM_PRESET_COLORS.length], flexShrink: 0 }} />
                    <span style={{ flex: 1, fontWeight: 600, fontSize: 13, color: t.text, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{team.name}</span>
                    <span style={{ fontSize: 11, color: t.textDim, background: mode === "dark" ? "#282b38" : "#eaeef2", padding: "1px 8px", borderRadius: 10, flexShrink: 0 }}>{team.members.length}</span>
                  </div>
                );
              })}
            </div>
            <div style={{ padding: 8, borderTop: `1px solid ${t.border}` }}>
              <button onClick={addTeam} style={{ width: "100%", padding: 10, background: t.btnBg, border: "none", borderRadius: 6, color: t.btnFg, cursor: "pointer", fontWeight: 700, fontSize: 12, display: "flex", alignItems: "center", justifyContent: "center", gap: 5 }}>
                <LuIcon name="plus" size={14} /> 팀 추가
              </button>
            </div>
          </div>

          {/* 우측 상세 */}
          {!isMobile && selectedTeam ? (
            <div style={{ flex: 1, overflowY: "auto", padding: 20, minHeight: 0 }}>
              {/* 팀명 */}
              <div style={{ marginBottom: 16 }}>
                {editingName !== null ? (
                  <div style={{ display: "flex", gap: 6, alignItems: "center" }}>
                    <input value={editingName} onChange={e => setEditingName(e.target.value)} style={{ ...iS, flex: 1, fontSize: 16, fontWeight: 700 }} autoFocus onKeyDown={e => { if (e.key === "Enter") renameTeam(editingName); if (e.key === "Escape") setEditingName(null); }} />
                    <button onClick={() => renameTeam(editingName)} style={{ padding: "6px 12px", background: t.btnBg, border: "none", borderRadius: 6, color: t.btnFg, cursor: "pointer", fontWeight: 600, fontSize: 12 }}>저장</button>
                  </div>
                ) : (
                  <div style={{ display: "flex", alignItems: "center", gap: 8 }}>
                    <h3 style={{ fontSize: 16, fontWeight: 700, color: t.text }}>{selectedTeam.name}</h3>
                    <button onClick={() => setEditingName(selectedTeam.name)} style={{ background: "none", border: "none", color: t.textDim, cursor: "pointer", padding: 2 }}><LuIcon name="pencil" size={14} /></button>
                  </div>
                )}
              </div>

              {/* 팀 컬러 */}
              <div style={{ marginBottom: 16 }}>
                <div style={{ fontSize: 12, fontWeight: 600, color: t.accent, marginBottom: 6 }}>팀 컬러</div>
                <div style={{ display: "flex", gap: 6, flexWrap: "wrap", alignItems: "center" }}>
                  {TEAM_PRESET_COLORS.map(c => (
                    <span key={c} onClick={() => setTeamColors(prev => ({ ...prev, [selectedTeam.id]: c }))}
                      style={{ width: 24, height: 24, borderRadius: "50%", background: c, cursor: "pointer", border: (teamColors[selectedTeam.id] || TEAM_PRESET_COLORS[0]) === c ? `2px solid ${t.text}` : `2px solid transparent`, display: "inline-block" }} />
                  ))}
                  <input type="color" value={teamColors[selectedTeam.id] || TEAM_PRESET_COLORS[0]} onChange={e => setTeamColors(prev => ({ ...prev, [selectedTeam.id]: e.target.value }))} style={{ width: 24, height: 24, border: "none", padding: 0, cursor: "pointer", borderRadius: 4 }} />
                </div>
              </div>

              {/* 멤버 리스트 */}
              <div style={{ marginBottom: 16 }}>
                <div style={{ fontSize: 12, fontWeight: 600, color: t.accent, marginBottom: 8 }}>멤버 ({selectedTeam.members.length}명)</div>
                {selectedTeam.members.map((member, mIdx) => {
                  const isEditing = editingMemberId === member.id;
                  const isLeader = member.role === "팀장" || member.role === "실장";
                  const isDragOver = mDragOverIdx === mIdx && mDragIdx !== mIdx;
                  const rtc = ROLE_TAG_COLORS[member.functionalRole];
                  const rc = rtc ? rtc[mode] : null;
                  return (
                    <div key={member.id} draggable onDragStart={(e) => { setMDragIdx(mIdx); e.dataTransfer.effectAllowed = "move"; }} onDragOver={(e) => { e.preventDefault(); setMDragOverIdx(mIdx); }} onDrop={() => handleMemberDrop(mIdx)} onDragEnd={() => { setMDragIdx(null); setMDragOverIdx(null); }}
                      style={{ padding: "8px 10px", marginBottom: 2, background: isEditing ? t.hoverBg : "transparent", border: `1px solid ${isDragOver ? t.accent : "transparent"}`, borderRadius: 6, transition: "background .1s" }}>
                      {isEditing ? (
                        <div style={{ display: "flex", flexDirection: "column", gap: 8 }}>
                          <div style={{ display: "flex", gap: 6 }}>
                            <input value={editFields.name ?? member.name} onChange={e => setEditFields(p => ({ ...p, name: e.target.value }))} style={{ ...iS, flex: 1 }} placeholder="이름" autoFocus />
                            <select value={editFields.functionalRole ?? (member.functionalRole || "")} onChange={e => setEditFields(p => ({ ...p, functionalRole: e.target.value }))} style={{ ...iS, width: 100 }}>
                              <option value="">역할 선택</option>
                              {MEMBER_ROLE_OPTIONS.map(r => <option key={r} value={r}>{r}</option>)}
                            </select>
                          </div>
                          <div style={{ display: "flex", gap: 6 }}>
                            <input value={editFields.p4Account ?? (member.p4Account || "")} onChange={e => setEditFields(p => ({ ...p, p4Account: e.target.value }))} style={{ ...iS, flex: 1 }} placeholder="P4 계정" />
                            <input value={editFields.memo ?? (member.memo || "")} onChange={e => setEditFields(p => ({ ...p, memo: e.target.value }))} style={{ ...iS, flex: 1 }} placeholder="메모" />
                          </div>
                          <div style={{ display: "flex", gap: 6, justifyContent: "flex-end" }}>
                            <button onClick={() => { setEditingMemberId(null); setEditFields({}); }} style={{ padding: "4px 10px", background: "transparent", border: `1px solid ${t.border}`, borderRadius: 4, color: t.textDim, cursor: "pointer", fontSize: 11 }}>취소</button>
                            <button onClick={() => saveMemberEdit(member.id)} style={{ padding: "4px 10px", background: t.btnBg, border: "none", borderRadius: 4, color: t.btnFg, cursor: "pointer", fontSize: 11, fontWeight: 600 }}>저장</button>
                          </div>
                        </div>
                      ) : (
                        <div style={{ display: "flex", alignItems: "center", gap: 6 }}>
                          <span style={{ cursor: "grab", color: t.textDim, flexShrink: 0 }}><LuIcon name="gripVertical" size={12} /></span>
                          {isLeader && <span style={{ color: "#d4a020", fontSize: 12, flexShrink: 0 }}>★</span>}
                          <span style={{ flex: 1, fontSize: 13, fontWeight: isLeader ? 700 : 400, color: t.text, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: "nowrap" }}>{member.name}</span>
                          {member.functionalRole && rc && <span style={{ fontSize: 10, padding: "2px 8px", borderRadius: 10, border: `1px solid ${rc.border}`, background: rc.bg, color: rc.color, flexShrink: 0 }}>{member.functionalRole}</span>}
                          {member.functionalRole && !rc && <span style={{ fontSize: 10, color: t.textDim, flexShrink: 0 }}>{member.functionalRole}</span>}
                          <div style={{ display: "flex", gap: 2, flexShrink: 0 }}>
                            {!isLeader && <button onClick={() => setLeader(member.id)} title="팀장 지정" style={{ background: "none", border: "none", color: t.textDim, cursor: "pointer", padding: 2 }}><LuIcon name="star" size={12} /></button>}
                            <button onClick={() => { setEditingMemberId(member.id); setEditFields({ name: member.name, functionalRole: member.functionalRole || "", p4Account: member.p4Account || "", memo: member.memo || "" }); }} title="편집" style={{ background: "none", border: "none", color: t.textDim, cursor: "pointer", padding: 2 }}><LuIcon name="pencil" size={12} /></button>
                            <button onClick={() => removeMember(member.id)} title="삭제" style={{ background: "none", border: "none", color: t.accentAlt, cursor: "pointer", padding: 2, opacity: 0.6 }}><LuIcon name="trash2" size={12} /></button>
                          </div>
                        </div>
                      )}
                    </div>
                  );
                })}

                {/* 멤버 추가 */}
                {addingMember ? (
                  <div style={{ padding: "8px 10px", display: "flex", gap: 6, alignItems: "center" }}>
                    <input value={newMemberName} onChange={e => setNewMemberName(e.target.value)} style={{ ...iS, flex: 1 }} placeholder="이름 입력" autoFocus onKeyDown={e => { if (e.key === "Enter") addMemberToTeam(); if (e.key === "Escape") setAddingMember(false); }} />
                    <select value={newMemberRole} onChange={e => setNewMemberRole(e.target.value)} style={{ ...iS, width: 90 }}>
                      {MEMBER_ROLE_OPTIONS.map(r => <option key={r} value={r}>{r}</option>)}
                    </select>
                    <button onClick={addMemberToTeam} style={{ padding: "6px 10px", background: t.btnBg, border: "none", borderRadius: 4, color: t.btnFg, cursor: "pointer", fontSize: 11, fontWeight: 600 }}>추가</button>
                    <button onClick={() => setAddingMember(false)} style={{ padding: "6px 10px", background: "transparent", border: `1px solid ${t.border}`, borderRadius: 4, color: t.textDim, cursor: "pointer", fontSize: 11 }}>취소</button>
                  </div>
                ) : (
                  <button onClick={() => setAddingMember(true)} style={{ width: "100%", padding: 8, background: "transparent", border: `1px dashed ${t.border}`, borderRadius: 6, color: t.textDim, cursor: "pointer", fontSize: 12, marginTop: 4, display: "flex", alignItems: "center", justifyContent: "center", gap: 4 }}>
                    <LuIcon name="userPlus" size={12} /> 멤버 추가
                  </button>
                )}
              </div>

              {/* 팀 삭제 */}
              <div style={{ borderTop: `1px solid ${t.border}`, paddingTop: 16 }}>
                <button onClick={() => deleteTeam(selectedTeam)} style={{ padding: "8px 16px", background: "transparent", border: `1px solid ${mode === "dark" ? "#8f5560" : "#cf222e"}`, borderRadius: 6, color: mode === "dark" ? "#c08888" : "#cf222e", cursor: "pointer", fontSize: 12, fontWeight: 600, display: "flex", alignItems: "center", gap: 5 }}>
                  <LuIcon name="trash2" size={14} /> 팀 삭제
                </button>
              </div>
            </div>
          ) : !isMobile ? (
            <div style={{ flex: 1, display: "flex", alignItems: "center", justifyContent: "center", color: t.textDim, fontSize: 13 }}>좌측에서 팀을 선택하세요</div>
          ) : null}
        </div>
      )}

      {/* 표시 설정 */}
      {teamConfigSubTab === "display" && (
        <div style={{ flex: 1, overflowY: "auto", padding: isMobile ? 16 : 24, minHeight: 0 }}>
          <div style={{ maxWidth: 500, margin: "0 auto" }}>
            <div style={{ fontSize: 13, fontWeight: 600, color: t.accent, marginBottom: 16 }}>간트 차트 설정</div>
            {[
              { label: "행 높이", key: "rowHeight", min: 20, max: 40, unit: "px" },
              { label: "셀 너비", key: "cellWidth", min: 20, max: 40, unit: "px" },
              { label: "작업 바 글씨", key: "taskBarFontSize", min: 8, max: 14, unit: "px" },
              { label: "마일스톤 바 높이", key: "milestoneBarHeight", min: 14, max: 24, unit: "px" },
            ].map(s => (
              <div key={s.key} style={{ marginBottom: 14, display: "flex", alignItems: "center", gap: 12 }}>
                <span style={{ fontSize: 12, fontWeight: 600, minWidth: 110, color: t.text }}>{s.label}</span>
                <input type="range" min={s.min} max={s.max} value={displaySettings[s.key]} onChange={e => setDisplaySettings(prev => ({ ...prev, [s.key]: parseInt(e.target.value) }))} style={{ flex: 1, accentColor: t.accent }} />
                <span style={{ fontSize: 12, color: t.textDim, minWidth: 36, textAlign: "right" }}>{displaySettings[s.key]}{s.unit}</span>
                {displaySettings[s.key] !== DISPLAY_DEFAULTS[s.key] && <button onClick={() => setDisplaySettings(prev => ({ ...prev, [s.key]: DISPLAY_DEFAULTS[s.key] }))} style={{ fontSize: 10, padding: "2px 6px", background: t.border, border: "none", borderRadius: 4, color: t.textDim, cursor: "pointer" }}>초기화</button>}
              </div>
            ))}

            <div style={{ borderTop: `1px solid ${t.border}`, paddingTop: 16, marginTop: 8 }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: t.accent, marginBottom: 12 }}>팀 표시 순서</div>
              {teams.map((team, idx) => (
                <div key={team.id} draggable onDragStart={(e) => handleTeamDragStart(e, idx)} onDragOver={(e) => handleTeamDragOver(e, idx)} onDrop={() => handleTeamDrop(idx)} onDragEnd={handleTeamDragEnd}
                  style={{ padding: "8px 12px", marginBottom: 2, background: (teamDragOverIdx === idx && teamDragIdx !== idx) ? t.hoverBg : "transparent", border: `1px solid ${t.border}`, borderRadius: 4, display: "flex", alignItems: "center", gap: 8, cursor: "grab" }}>
                  <LuIcon name="gripVertical" size={12} color={t.textDim} />
                  <span style={{ width: 8, height: 8, borderRadius: "50%", background: teamColors[team.id] || TEAM_PRESET_COLORS[idx % TEAM_PRESET_COLORS.length] }} />
                  <span style={{ fontSize: 12, color: t.text }}>{team.name}</span>
                  <span style={{ fontSize: 11, color: t.textDim, marginLeft: "auto" }}>{team.members.length}명</span>
                </div>
              ))}
            </div>

            <div style={{ borderTop: `1px solid ${t.border}`, paddingTop: 16, marginTop: 16 }}>
              <div style={{ fontSize: 13, fontWeight: 600, color: t.accent, marginBottom: 12 }}>팀 접기 기본값</div>
              {teams.map(team => (
                <label key={team.id} style={{ display: "flex", alignItems: "center", gap: 8, padding: "6px 0", cursor: "pointer" }}>
                  <input type="checkbox" checked={defaultCollapsedTeams.includes(team.id)} onChange={e => setDefaultCollapsedTeams(prev => e.target.checked ? [...prev, team.id] : prev.filter(id => id !== team.id))} style={{ accentColor: t.accent }} />
                  <span style={{ fontSize: 12, color: t.text }}>{team.name}</span>
                  <span style={{ fontSize: 10, color: t.textDim }}> — 앱 로드 시 접힌 상태</span>
                </label>
              ))}
            </div>
          </div>
        </div>
      )}

      {/* 삭제 확인 모달 */}
      {confirmDel && (
        <div style={{ position: "fixed", top: 0, left: 0, right: 0, bottom: 0, background: "rgba(0,0,0,0.5)", display: "flex", alignItems: "center", justifyContent: "center", zIndex: 300 }}>
          <div style={{ background: t.panelBg, borderRadius: 10, padding: 24, maxWidth: 360, width: "90%", border: `1px solid ${t.border}` }}>
            <h4 style={{ color: t.text, fontSize: 14, marginBottom: 10 }}>{confirmDel.title}</h4>
            <p style={{ color: t.textDim, fontSize: 12, whiteSpace: "pre-line", marginBottom: 16 }}>{confirmDel.message}</p>
            <div style={{ display: "flex", gap: 8, justifyContent: "flex-end" }}>
              <button onClick={() => setConfirmDel(null)} style={{ padding: "8px 16px", background: "transparent", border: `1px solid ${t.border}`, borderRadius: 6, color: t.textDim, cursor: "pointer", fontSize: 12 }}>취소</button>
              <button onClick={confirmDel.onConfirm} style={{ padding: "8px 16px", background: mode === "dark" ? "#8f5560" : "#cf222e", border: "none", borderRadius: 6, color: "#fff", cursor: "pointer", fontSize: 12, fontWeight: 600 }}>삭제</button>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}
