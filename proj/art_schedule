                return group.dates.map((date, idx) => {
                  const ds = fmt(date);
                  const entry = updateData[ds] || {};
                  const items = toArr(entry.items);
                  const iTeams = entry.itemTeams || [];
                  const iJiras = entry.itemJiras || [];
                  const isSel = selSet.has(ds);
                  const msName = entry.milestone || "";
                  const msMatch = msName ? milestones.find(m => m.name === msName) : null;
                  const artDl = msMatch ? msMatch.endDate : "";
                  const isDragOver = dragOverDate === ds;
                  const isEmpty = items.length === 0 || (items.length === 1 && items[0] === "-");
                  const emptyBg = dk ? "#1e2029" : "#f6f8fa";
                  const hasTeamMatch = (teamArr) => updateTeamFilter === "전체" || (teamArr && teamArr.some(tn => tn === updateTeamFilter || (updateTeamFilter === "배경_제작" && tn.startsWith("배경_제작"))));
                  const filteredIdxs = items.map((_, i) => i).filter(i => {
                    if (items[i] === "-") return updateTeamFilter === "전체";
                    return hasTeamMatch(iTeams[i]);
                  });
                  // 아트 마감 임박 행 하이라이트
                  const artDdayVal = calcDday(artDl);
                  const artUrgent = artDdayVal !== null && artDdayVal >= 0 && artDdayVal <= 7;
                  const urgentRowBg = artUrgent ? (dk ? "rgba(160,85,96,0.04)" : "rgba(160,85,96,0.03)") : null;
                  const baseBg = isEmpty ? emptyBg : idx % 2 === 0 ? t.tableBg : t.tableAlt;
                  const rowBg = isDragOver ? (dk ? "rgba(120,137,168,0.10)" : "rgba(9,105,218,.08)") : isSel ? (dk ? "rgba(120,137,168,0.12)" : "rgba(9,105,218,.1)") : urgentRowBg || baseBg;
                  const normalBg = urgentRowBg || baseBg;
                  // 항목 개수 배지
                  const itemCount = filteredIdxs.filter(i => items[i] && items[i] !== "-").length;
                  const badgeBg = itemCount === 0 ? "transparent" : itemCount <= 2 ? (dk ? "#586070" : "#8c959f") : itemCount <= 4 ? (dk ? "#9e8548" : "#9a6700") : (dk ? "#a05560" : "#cf222e");
                  const badgeFg = itemCount >= 3 ? "#fff" : (dk ? "#c4c8d0" : "#fff");
                  return (
                    <tr key={ds}
                      onDragOver={(e) => { if (dragItem) { e.preventDefault(); setDragOverDate(ds); } }}
                      onDragLeave={() => { if (dragOverDate === ds) setDragOverDate(null); }}
                      onDrop={(e) => { e.preventDefault(); if (dragItem) { const toKey = dragItem.field === "pending" ? mk : ds; if (dragItem.fromDate !== toKey) moveItem(dragItem.fromDate, toKey, dragItem.field, dragItem.index); } setDragItem(null); setDragOverDate(null); }}
                      onMouseDown={(e) => { if (e.button === 0 && !e.target.closest("[draggable]")) { updateDragRef.current = ds; setUpdateSelect(null); } }}
                      onMouseEnter={() => { if (updateDragRef.current && updateDragRef.current !== ds) setUpdateSelect({ start: updateDragRef.current, end: ds }); }}
                      onClick={() => openPopup(ds)}
                      style={{
                        background: rowBg,
                        boxShadow: artUrgent ? `inset 3px 0 0 ${dk ? "#a05560" : "#cf222e"}` : "none",
                        cursor: "pointer", transition: "background 0.1s"
                      }}
                      title={isEmpty ? "항목 없음" : ""}
                      onMouseOver={(e) => { if (!isSel && !isDragOver && !updateDragRef.current && !dragItem) e.currentTarget.style.background = t.tableHover; }} onMouseOut={(e) => { if (!isSel && !isDragOver) e.currentTarget.style.background = normalBg; }}>
                      {idx === 0 && <td rowSpan={group.dates.length} style={{ ...tdS(t), padding: cellPad, fontWeight: 700, verticalAlign: "top" }}>{group.month}월</td>}
                      <td style={{ ...tdS(t), padding: isEmpty ? cellPadEmpty : cellPad, fontWeight: 600, whiteSpace: "nowrap" }}>
                        <div style={{ display: "flex", alignItems: "center", justifyContent: "center", gap: 4 }}>
                          <span>{date.getDate()}일</span>
                          {itemCount > 0 && <span style={{ display: "inline-flex", alignItems: "center", justifyContent: "center", width: 20, height: 20, borderRadius: "50%", background: badgeBg, color: badgeFg, fontSize: 11, fontWeight: 700, lineHeight: 1, flexShrink: 0 }}>{itemCount}</span>}
                        </div>
                        {msName ? <span style={{ fontSize: 11, opacity: 0.7, display: "block" }}>({msName})</span> : ""}
                      </td>
                      <td style={{ ...tdS(t), padding: isEmpty ? cellPadEmpty : cellPad, textAlign: "left" }}>
                        {isEmpty ? null : filteredIdxs.map((i) => {
                          const it = items[i];
                          const tagTeams = iTeams[i] || [];
                          const jiraUrl = iJiras[i] || "";
                          return (
                          <span key={i} draggable
                            onDragStart={(e) => { e.stopPropagation(); setDragItem({ fromDate: ds, index: i, field: "items" }); e.dataTransfer.effectAllowed = "move"; }}
                            onDragEnd={() => { setDragItem(null); setDragOverDate(null); }}
                            onMouseDown={(e) => e.stopPropagation()}
                            onClick={(e) => { e.stopPropagation(); setEditingUpdate(ds); }}
                            style={chipS(dragItem && dragItem.fromDate === ds && dragItem.field === "items" && dragItem.index === i)}
                          >{jiraUrl && <a href={jiraUrl} target="_blank" rel="noopener noreferrer" onClick={(e) => e.stopPropagation()} title="JIRA" style={{ display: "inline-flex", flexShrink: 0, color: "#2684ff" }}><LuIcon name="externalLink" size={12} color="#2684ff" /></a>}<span style={{ flex: 1, overflow: "hidden", textOverflow: "ellipsis", whiteSpace: isMobile ? "normal" : "nowrap", wordBreak: isMobile ? "break-all" : undefined }}>{it}</span>{!isMobile && tagTeams.map(tn => { const tc = TEAM_TAG_COLORS[tn] || TEAM_TAG_COLORS[(Object.keys(TEAM_TAG_COLORS).find(k => tn.startsWith(k)))] || TEAM_TAG_COLORS["공통"]; const c = tc[mode] || tc.dark; return <span key={tn} style={{ padding: "2px 8px", fontSize: 10, borderRadius: 10, border: `1px solid ${c.border}`, background: c.bg, color: c.color, whiteSpace: "nowrap", flexShrink: 0 }}>{tn}</span>; })}</span>
                          );
                        })}
                      </td>
                      {idx === 0 && <td rowSpan={group.dates.length} style={{ ...tdS(t), padding: cellPad, textAlign: "left", verticalAlign: "top" }}
                        onDragOver={(e) => { if (dragItem && dragItem.field === "pending") { e.preventDefault(); e.stopPropagation(); } }}
                        onDrop={(e) => { if (dragItem && dragItem.field === "pending" && dragItem.fromDate !== mk) { e.preventDefault(); e.stopPropagation(); moveItem(dragItem.fromDate, mk, "pending", dragItem.index); setDragItem(null); setDragOverDate(null); } }}>
                        {mPending.length > 0 ? mPending.map((it, i) => (
                          <span key={i} draggable
                            onDragStart={(e) => { e.stopPropagation(); setDragItem({ fromDate: mk, index: i, field: "pending" }); e.dataTransfer.effectAllowed = "move"; }}
                            onDragEnd={() => { setDragItem(null); setDragOverDate(null); }}
                            onMouseDown={(e) => e.stopPropagation()}
                            onClick={(e) => { e.stopPropagation(); setEditingUpdate(ds); }}
                            style={pendChipS(dragItem && dragItem.fromDate === mk && dragItem.field === "pending" && dragItem.index === i)}
                          >{it}</span>
                        )) : <span style={{ color: t.textDim }}>-</span>}
                      </td>}
                      {!isMobile && (() => {
                        const ddayCell = (dateStr) => {
                          if (!dateStr) return <td style={{ ...tdS(t), padding: cellPad, color: t.textDim, fontSize: 12 }}>-</td>;
                          const dd = calcDday(dateStr);
                          const ds2 = ddayColor(dd, mode);
                          const leftC = dd !== null && dd >= 0 && dd <= 7 ? (dk ? "#a05560" : "#cf222e") : "transparent";
                          const bg2 = dd !== null && dd >= 0 && dd <= 3 ? (dk ? "rgba(160,85,96,0.08)" : "rgba(207,34,46,0.04)") : undefined;
                          return (
                            <td style={{ ...tdS(t), padding: cellPad, boxShadow: leftC !== "transparent" ? `inset 3px 0 0 ${leftC}` : "none", background: bg2 }}>
                              <div style={{ fontSize: 11, opacity: 0.7, marginBottom: 2 }}>{fmtDateKR(dateStr)}</div>
                              <div style={{ fontSize: 13, fontWeight: 700, ...ds2 }}>{fmtDday(dd)}</div>
                            </td>
                          );
                        };
                        return <>{ddayCell(artDl)}{ddayCell(entry.firstMerge)}{ddayCell(entry.lastMerge)}</>;
                      })()}
                    </tr>
                  );
                });
              })}
            </tbody>
          </table>
          </div>{/* end scroll wrapper */}
        </div>
        );
      })()}

      {/* ─── 자리배치도 탭 ─── */}
      {/* ─── 대시보드 탭 ─── */}
      {tab === "dashboard" && (
        <div style={{ flex: 1, overflow: "auto", padding: isMobile ? 12 : 20, minHeight: 0 }}>
          {milestones.length > 0 && (() => {
            const dk = mode === "dark";
            const sorted = [...milestones].sort((a, b) => {
              const aLive = a.status === "live" ? 1 : 0, bLive = b.status === "live" ? 1 : 0;
              if (aLive !== bLive) return aLive - bLive;
              if (aLive) return b.endDate.localeCompare(a.endDate);
              return a.endDate.localeCompare(b.endDate);
            });
            return (
              <div style={{ marginBottom: isMobile ? 16 : 20 }}>
                <h3 style={{ margin: "0 0 10px", color: t.text, fontSize: 15, fontWeight: 700, display: "flex", alignItems: "center", gap: 6 }}>
                  <LuIcon name="flag" size={16} /> 마일스톤 현황
                </h3>
                <div style={{ display: "grid", gridTemplateColumns: `repeat(auto-fill, minmax(${isMobile ? 150 : 200}px, 1fr))`, gap: 12 }}>
                  {sorted.map(ms => {
                    const dd = calcDday(ms.endDate);
                    const isLive = ms.status === "live";
                    const isUrgent = !isLive && dd !== null && dd <= 7 && dd >= 0;
                    const msUpdates = milestoneUpdatesMap[ms.name] || [];
                    const allItemKeys = msItemKeysMap[ms.name] || [];
                    const totalItems = allItemKeys.length;
                    const doneCount = allItemKeys.filter(key => completedItems[key]).length;
                    const pct = totalItems > 0 ? Math.round((doneCount / totalItems) * 100) : (isLive ? 100 : 0);
                    const allDone = totalItems > 0 && doneCount === totalItems;
                    const badgeBg = isLive ? (dk ? "#2d6b4f" : "rgba(26,127,55,.12)")
                      : isUrgent ? (dk ? "#6e3a42" : "rgba(207,34,46,.12)")
                      : (dk ? "#3b4d80" : "rgba(52,81,178,.12)");
                    const badgeColor = isLive ? (dk ? "#6fda8e" : "#1a7f37")
                      : isUrgent ? (dk ? "#e8a0aa" : "#cf222e")
                      : (dk ? "#8eaaed" : "#3451b2");
                    const barBg = dk ? t.border : "#e1e4e8";
                    const barFill = allDone ? (dk ? "#3a8a5e" : "#2da44e")
                      : isUrgent ? (dk ? "#a05560" : "#cf222e")
                      : (dk ? "#5068a8" : "#3451b2");
                    const isExpanded = expandedMsId === ms.id;
                    return (
                      <div key={ms.id} onClick={() => setExpandedMsId(prev => prev === ms.id ? null : ms.id)}
                        style={{ background: dk ? t.panelBg : "#f6f8fa",
                          border: `1px solid ${isExpanded ? (dk ? t.accent : "#0969da") : (dk ? t.border : "#d0d7de")}`,
                          borderRadius: 8, padding: isMobile ? "10px 12px" : "12px 16px", cursor: "pointer",
                          transition: "border-color .15s" }}
                        onMouseOver={e => { if (!isExpanded) e.currentTarget.style.borderColor = dk ? "#4a5568" : "#8c959f"; }}
                        onMouseOut={e => { if (!isExpanded) e.currentTarget.style.borderColor = dk ? t.border : "#d0d7de"; }}>
                        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 6 }}>
                          <span style={{ fontSize: 15, fontWeight: 700, color: t.text }}>{ms.name}</span>
                          <span style={{ fontSize: 11, fontWeight: 600, padding: "2px 8px", borderRadius: 4,
                            background: badgeBg, color: badgeColor }}>{isLive ? "라이브" : isUrgent ? "마감임박" : "라이브 예정"}</span>
                        </div>
                        <div style={{ fontSize: 12, color: t.textDim, marginBottom: 4 }}>
                          {fmtDateKR(ms.startDate)} ~ {fmtDateKR(ms.endDate)}
                        </div>
                        {dd !== null && (
                          <div style={{ fontSize: 13, fontWeight: 600, marginBottom: 8,
                            color: allDone ? (dk ? "#6fda8e" : "#1a7f37") : isUrgent ? (dk ? "#e8a0aa" : "#cf222e") : (dk ? "#8eaaed" : "#3451b2") }}>
                            {allDone ? "아트실 작업 모두 완료" : dd === 0 ? "D-Day" : dd > 0 ? `D-${dd}` : `D+${Math.abs(dd)}`}
                          </div>
                        )}
                        <div style={{ height: 6, borderRadius: 3, background: barBg, overflow: "hidden" }}>
                          <div style={{ height: "100%", width: `${Math.min(100, pct)}%`, borderRadius: 3,
                            background: barFill, transition: "width .3s" }} />
                        </div>
                        <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginTop: 4 }}>
                          <span style={{ fontSize: 11, color: t.textDim }}>{totalItems > 0 ? `${doneCount}/${totalItems}` : ""} {pct}%</span>
                          <LuIcon name={isExpanded ? "chevronUp" : "chevronDown"} size={12} style={{ color: t.textDim }} />
                        </div>
                        {msUpdates.length > 0 && !isExpanded && (
                          <div style={{ display: "flex", gap: 4, flexWrap: "wrap", marginTop: 6 }}>
                            {msUpdates.map(([dateStr]) => {
                              const udd = calcDday(dateStr);
                              const isPast = udd !== null && udd < 0;
                              const dp = new Date(dateStr + "T00:00:00");
                              return (
                                <span key={dateStr} style={{ fontSize: 11, padding: "1px 6px", borderRadius: 3,
                                  background: isPast ? (dk ? "#282b38" : "#f0f3f6") : (dk ? "rgba(120,137,168,0.12)" : "rgba(9,105,218,.08)"),
                                  color: isPast ? t.textDim : (dk ? "#8eaaed" : "#3451b2"),
                                  textDecoration: isPast ? "line-through" : "none" }}>
                                  {dp.getMonth() + 1}/{dp.getDate()}
                                </span>
                              );
                            })}
                          </div>
                        )}
                        {isExpanded && (
                          <div style={{ borderTop: `1px solid ${t.border}`, marginTop: 8, paddingTop: 8 }}>
                            <div style={{ fontSize: 12, fontWeight: 600, color: t.textDim, marginBottom: 6, display: "flex", alignItems: "center", gap: 4 }}>
                              <LuIcon name="calendar" size={12} /> 업데이트 일정
                            </div>
                            {msUpdates.length === 0 ? (
                              <div style={{ fontSize: 12, color: t.textDim, fontStyle: "italic" }}>(업데이트 없음)</div>
                            ) : msUpdates.map(([dateStr, entry]) => {
                              const dp = new Date(dateStr + "T00:00:00");
                              const udd = calcDday(dateStr);
                              const isPast = udd !== null && udd < 0;
                              return (
                                <div key={dateStr} style={{ marginBottom: 8 }}>
                                  <div style={{ fontSize: 12, fontWeight: 600, color: isPast ? t.textDim : t.text, marginBottom: 3, display: "flex", alignItems: "center", gap: 4,
                                    textDecoration: isPast ? "line-through" : "none" }}>
                                    <span>{dp.getMonth() + 1}/{dp.getDate()}</span>
                                    {udd !== null && !isPast && <span style={{ fontSize: 11, fontWeight: 500, color: udd <= 7 ? (dk ? "#e8a0aa" : "#cf222e") : (dk ? "#8eaaed" : "#3451b2") }}>{udd === 0 ? "D-Day" : `D-${udd}`}</span>}
                                  </div>
                                  {(() => {
                                    const validItems = (entry.items || []).map((x, idx) => ({ item: x, idx })).filter(({ item: x }) => x && x !== "-");
                                    return validItems.length > 0 ? validItems.map(({ item, idx: origIdx }) => {
                                    const itemKey = `${ms.name}:${dateStr}:${origIdx}`;
                                    const isDone = !!completedItems[itemKey];
                                    return (
                                      <div key={origIdx} onClick={e => e.stopPropagation()}
                                        style={{ fontSize: 12, paddingLeft: 4, lineHeight: 1.5, display: "flex", alignItems: "center", gap: 6, marginBottom: 2 }}>
                                        <span onClick={() => setCompletedItems(prev => { const n = { ...prev }; if (n[itemKey]) delete n[itemKey]; else n[itemKey] = true; return n; })}
                                          style={{ width: 16, height: 16, borderRadius: 3, flexShrink: 0, cursor: "pointer", display: "flex", alignItems: "center", justifyContent: "center",
                                            border: `1.5px solid ${isDone ? (dk ? "#3a8a5e" : "#2da44e") : (dk ? "#4a5568" : "#d0d7de")}`,
                                            background: isDone ? (dk ? "#2d6b4f" : "rgba(26,127,55,.12)") : "transparent",
                                            transition: "all .15s" }}>
                                          {isDone && <LuIcon name="check" size={10} style={{ color: dk ? "#6fda8e" : "#1a7f37" }} />}
                                        </span>
                                        <span style={{ color: isDone ? t.textDim : t.text, textDecoration: isDone ? "line-through" : "none" }}>{item}</span>
                                        <span style={{ fontSize: 10, padding: "1px 5px", borderRadius: 3, marginLeft: "auto", flexShrink: 0,
                                          background: isDone ? (dk ? "#2d6b4f" : "rgba(26,127,55,.1)") : (dk ? "rgba(120,137,168,0.10)" : "rgba(9,105,218,.06)"),
                                          color: isDone ? (dk ? "#6fda8e" : "#1a7f37") : (dk ? "#7889a8" : "#57606a") }}>
                                          {isDone ? "완료" : "진행중"}
                                        </span>
                                      </div>
                                    );
                                  }) : <div style={{ fontSize: 12, color: t.textDim, paddingLeft: 10, fontStyle: "italic" }}>(항목 없음)</div>;
                                  })()}
                                </div>
                              );
                            })}
                          </div>
                        )}
                        {(() => {
                          const ae = archiveEligibility[ms.id];
                          if (!ae || ae.reason === 'not_ended') return null;
                          if (ae.eligible) return (
                            <button onClick={(e) => { e.stopPropagation(); setShowArchiveConfirm(ms); }}
                              style={{ marginTop: 8, padding: "4px 10px", fontSize: 11, fontWeight: 600, background: dk ? "rgba(120,137,168,0.10)" : "rgba(9,105,218,0.06)", color: dk ? "#7889a8" : "#0969da", border: `1px solid ${dk ? "#323544" : "#d0d7de"}`, borderRadius: 5, cursor: "pointer", display: "inline-flex", alignItems: "center", gap: 4 }}>
                              {"\uD83D\uDCE6"} 아카이브
                            </button>
                          );
                          if (ae.reason === 'incomplete') return (
                            <button onClick={(e) => { e.stopPropagation(); setShowArchiveConfirm(ms); }}
                              title={`미완료 작업 ${ae.count}건 — 클릭하여 확인`}
                              style={{ marginTop: 8, padding: "4px 10px", fontSize: 11, fontWeight: 600, background: dk ? "rgba(160,85,96,0.10)" : "rgba(207,34,46,0.06)", color: dk ? "#e8a0aa" : "#cf222e", border: `1px solid ${dk ? "#4a3040" : "#f0d0d4"}`, borderRadius: 5, cursor: "pointer", display: "inline-flex", alignItems: "center", gap: 4 }}>
                              {"\uD83D\uDCE6"} {ae.count}건 미완료
                            </button>
                          );
                          return null;
                        })()}
                      </div>
                    );
                  })}
                </div>
              </div>
            );
          })()}
        </div>
      )}
      {/* ─── 기기/TO 현황 탭 ─── */}
      {tab === "extra" && extraView === "equipment" && (
        <div style={{ flex: 1, overflow: "auto", padding: isMobile ? 12 : 20, minHeight: 0 }}>
          <div style={{ display: "flex", gap: isMobile ? 16 : 24, flexWrap: "wrap", alignItems: "flex-start" }}>
            {/* 기기 보유 현황 */}
            <div style={{ flex: 1, minWidth: isMobile ? 0 : 380, width: isMobile ? "100%" : undefined }}>
              <div style={{ display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 8 }}>
                <h3 style={{ margin: 0, color: t.text, fontSize: 15, fontWeight: 700 }}>기기 보유 현황</h3>
                <button onClick={() => setEditingDevice({ id: null, model: "", team: "", holder: "", returned: false, returnDate: "" })}
                  style={{ padding: "4px 12px", background: t.btnBg, border: "none", borderRadius: 5, color: t.btnFg, cursor: "pointer", fontSize: 12, fontWeight: 600, display: "inline-flex", alignItems: "center", gap: 4 }}><LuIcon name="plus" size={12} /> 추가</button>
              </div>
              <div style={{ overflowX: "auto", WebkitOverflowScrolling: "touch" }}>
              <table style={{ width: "100%", minWidth: isMobile ? 340 : undefined, borderCollapse: "collapse", border: `1px solid ${t.border}`, fontSize: isMobile ? 12 : 13 }}>
                <thead><tr style={{ background: t.headerBg }}>
                  {["기종","팀","보유자","상태","반납일자"].map((h,i) => <th key={i} style={{ ...thS(t), fontSize: 12, padding: isMobile ? "5px 4px" : "7px 6px" }}>{h}</th>)}
                </tr></thead>
                <tbody>
                  {devices.map((dev, i) => (
                    <tr key={dev.id} onClick={() => setEditingDevice(dev)} style={{ background: i % 2 === 0 ? t.tableBg : t.tableAlt, cursor: "pointer" }}
                      onMouseOver={e => e.currentTarget.style.background = t.tableHover} onMouseOut={e => e.currentTarget.style.background = i % 2 === 0 ? t.tableBg : t.tableAlt}>
                      <td style={{ ...tdS(t), padding: "6px", fontWeight: 500, textAlign: "left" }}>{dev.model}</td>
                      <td style={{ ...tdS(t), padding: "6px" }}>{dev.returned ? "-" : (dev.team || "-")}</td>
                      <td style={{ ...tdS(t), padding: "6px" }}>{dev.returned ? "-" : (dev.holder || "-")}</td>
                      <td style={{ ...tdS(t), padding: "6px" }}>
                        <span style={{ padding: "2px 8px", borderRadius: 3, fontSize: 11, fontWeight: 600,
                          background: dev.returned ? (mode === "dark" ? "#323544" : "#f0f3f6") : (mode === "dark" ? "rgba(120,137,168,0.10)" : "rgba(26,127,55,.1)"),
                          color: dev.returned ? t.textDim : (mode === "dark" ? "#7889a8" : "#1a7f37") }}>
                          {dev.returned ? "반납" : "보유중"}
                        </span>
                      </td>
                      <td style={{ ...tdS(t), padding: "6px", fontSize: 12 }}>{dev.returned && dev.returnDate ? dev.returnDate : "-"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
              </div>{/* end device scroll wrapper */}
            </div>

            {/* TO 현황 */}
            <div style={{ flex: 1, minWidth: isMobile ? 0 : 340, width: isMobile ? "100%" : undefined }}>
              <h3 style={{ margin: "0 0 8px", color: t.text, fontSize: 15, fontWeight: 700 }}>TO 현황</h3>
              <div style={{ overflowX: "auto", WebkitOverflowScrolling: "touch" }}>
