  const up = (k, v) => setF((p) => ({ ...p, [k]: v }));
  const addItem = (field) => setF(p => ({ ...p, [field]: [...p[field], ""], ...(field === "items" ? { itemTeams: [...p.itemTeams, []], itemJiras: [...p.itemJiras, ""] } : {}) }));
  const updateItem = (field, idx, val) => setF(p => { const a = [...p[field]]; a[idx] = val; return { ...p, [field]: a }; });
  const removeItem = (field, idx) => setF(p => { const a = [...p[field]]; a.splice(idx, 1); const upd = { ...p, [field]: a }; if (field === "items") { const ta = [...p.itemTeams]; ta.splice(idx, 1); upd.itemTeams = ta; const ja = [...p.itemJiras]; ja.splice(idx, 1); upd.itemJiras = ja; } return upd; });
  const toggleItemTeam = (idx, teamName) => setF(p => { const ta = [...p.itemTeams]; const cur = [...(ta[idx] || [])]; const ti = cur.indexOf(teamName); if (ti >= 0) cur.splice(ti, 1); else cur.push(teamName); ta[idx] = cur; return { ...p, itemTeams: ta }; });
