              <button onClick={() => setShowArchiveConfirm(null)}
                style={{ flex: 1, padding: 12, background: t.border, border: "none", borderRadius: RADIUS.md, color: t.text, cursor: "pointer", fontWeight: 700, fontSize: 14 }}>{"취소"}</button>
            </div>
          </Modal>
        );
      })()}

      {/* ─── 아카이브 요약 모달 ─── */}
