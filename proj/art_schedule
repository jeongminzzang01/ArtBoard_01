            ); })}
          </div>
          <div style={{ display: "flex", alignItems: "center", gap: 6, marginTop: 6 }}>
            <LuIcon name="externalLink" size={14} color={f.itemJiras[i] ? "#2684ff" : t.textDim} style={{ flexShrink: 0 }} />
