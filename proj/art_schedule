    </div>
  );
  const doSave = () => { const validIdxs = f.items.map((v, i) => v ? i : -1).filter(i => i >= 0); const clean = { ...f, items: validIdxs.map(i => f.items[i]), itemTeams: validIdxs.map(i => f.itemTeams[i] || []), itemJiras: validIdxs.map(i => f.itemJiras[i] || ""), pending: f.pending.filter(Boolean) }; onSave(clean); };
