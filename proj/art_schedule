const calcDday = (dateStr) => {
  if (!dateStr) return null;
  const target = new Date(dateStr + "T00:00:00");
  const today = new Date(); today.setHours(0, 0, 0, 0);
  const diff = Math.round((target - today) / 86400000);
  return diff;
};
const fmtDday = (diff) => {
  if (diff === null || diff === undefined) return "";
  if (diff === 0) return "D-Day";
  if (diff > 0) return `D-${diff}`;
  return `D+${Math.abs(diff)}`;
};
const ddayColor = (diff, mode = "dark") => {
  if (diff === null || diff === undefined) return {};
  const dk = mode === "dark";
  if (diff < 0) return { color: dk ? "#7a8494" : "#8c959f", textDecoration: "line-through" };
  if (diff === 0) return { color: dk ? "#e8d0d3" : "#fff", background: dk ? "#a05560" : "#cf222e", borderRadius: 4, padding: "1px 5px", fontWeight: 700 };
  if (diff <= 6) return { color: dk ? "#a05560" : "#cf222e", fontWeight: 700 };
  if (diff <= 13) return { color: dk ? "#9e8548" : "#9a6700" };
  return { color: dk ? "#586070" : "#656d76" };
};

