          </div>
          <div style={{ display: "flex", gap: 5, flexWrap: "wrap", marginTop: 6 }}>
            {TEAM_TAG_NAMES.map(tn => { const sel = (f.itemTeams[i] || []).includes(tn); const tc = TEAM_TAG_COLORS[tn]; const c = tc[mode] || tc.dark; return (
