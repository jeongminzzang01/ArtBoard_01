function findColFromX(colXPos, x) {
  let lo = 0, hi = colXPos.length - 2;
  while (lo <= hi) {
    const mid = (lo + hi) >> 1;
    if (x < colXPos[mid]) hi = mid - 1;
    else if (x >= colXPos[mid + 1]) lo = mid + 1;
    else return mid;
  }
  return Math.max(0, Math.min(lo, colXPos.length - 2));
}

function genMonthDates(months) {
  const dates = [];
  months.forEach(({ year, month }) => {
    const dim = new Date(year, month + 1, 0).getDate();
    for (let d = 1; d <= dim; d++) { const dt = new Date(year, month, d); if (!isWeekend(dt)) dates.push(dt); }
  });
  return dates;
}
function genThursdays(months) {
  const res = [];
  months.forEach(({ year, month }) => {
    const dim = new Date(year, month + 1, 0).getDate();
    for (let d = 1; d <= dim; d++) { const dt = new Date(year, month, d); if (dt.getDay() === 4) res.push(dt); }
  });
  return res;
}

